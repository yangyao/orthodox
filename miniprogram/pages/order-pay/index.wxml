<navigation-bar title="订单支付" back="{{true}}"></navigation-bar>

<view class="container">
  <view class="order-info" wx:if="{{order}}">
    <text class="order-no">订单号：{{order.orderNo}}</text>
    <text class="order-amount">¥{{order.payAmountFen / 100}}</text>
  </view>

  <view class="section">
    <text class="section-title">选择支付方式</text>

    <view class="pay-method {{selectedMethod === 'wechat' ? 'selected' : ''}}" bindtap="onSelectMethod" data-method="wechat">
      <text class="method-label">微信支付</text>
      <view class="method-radio {{selectedMethod === 'wechat' ? 'checked' : ''}}"></view>
    </view>

    <view class="pay-method {{selectedMethod === 'wallet' ? 'selected' : ''}}" bindtap="onSelectMethod" data-method="wallet">
      <view class="method-info">
        <text class="method-label">余额支付</text>
        <text class="method-balance">余额：¥{{walletBalanceDisplay}}</text>
      </view>
      <view class="method-radio {{selectedMethod === 'wallet' ? 'checked' : ''}}"></view>
    </view>

    <view wx:if="{{selectedMethod === 'wallet' && walletBalance < (order ? order.payAmountFen : 0)}}" class="balance-tip">
      <text>余额不足，</text>
      <text class="link" bindtap="navToWallet">去充值</text>
    </view>
  </view>

  <button class="pay-btn" bindtap="onPay" disabled="{{paying || !order}}">
    {{paying ? '支付中...' : '确认支付'}}
  </button>
</view>
