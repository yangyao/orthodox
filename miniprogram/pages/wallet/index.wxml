<navigation-bar title="我的钱包" back="{{true}}"></navigation-bar>

<view class="container">
  <view class="balance-card">
    <text class="balance-label">账户余额（元）</text>
    <text class="balance-value">{{balanceDisplay}}</text>
  </view>

  <view class="section">
    <text class="section-title">选择充值档位</text>
    <view class="options-grid">
      <view
        wx:for="{{rechargeOptions}}"
        wx:key="optionCode"
        class="option-item {{selectedOptionCode === item.optionCode ? 'selected' : ''}}"
        bindtap="onSelectOption"
        data-code="{{item.optionCode}}"
      >
        <text class="option-coins">{{item.coins}} 币</text>
        <text class="option-price">¥{{item.amountFen / 100}}</text>
      </view>
    </view>
  </view>

  <button class="recharge-btn" bindtap="onRecharge" disabled="{{loading || !selectedOptionCode}}">
    {{loading ? '处理中...' : '立即充值'}}
  </button>

  <view class="ledger-entry" bindtap="navToLedger">
    <text class="ledger-label">账单明细</text>
    <text class="arrow">></text>
  </view>
</view>
